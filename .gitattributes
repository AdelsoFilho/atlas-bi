# Normalize line endings to LF on check-in (consistent across Windows/macOS/Linux)
* text=auto eol=lf

# Force LF for source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary — no conversion
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
