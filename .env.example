# ─── Atlas BI — Environment Variables Template ────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to version control.

# ── Data Source ───────────────────────────────────────────────────────────────
# REST API base URL for fleet data (leave empty to use built-in mock data)
VITE_API_BASE_URL=

# ── Real-time (WebSocket / SSE) ───────────────────────────────────────────────
# WebSocket endpoint for live incident streaming
VITE_WS_URL=

# ── Supabase (optional backend) ───────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable the AI risk prediction panel (Claude API)
VITE_ENABLE_AI_INSIGHTS=false

# ── Claude / Anthropic API (server-side only — do NOT expose in client) ───────
# Use a backend proxy; never put this key in a VITE_ prefixed variable in prod
ANTHROPIC_API_KEY=

# ── Vercel Analytics (optional) ───────────────────────────────────────────────
VITE_VERCEL_ANALYTICS_ID=
